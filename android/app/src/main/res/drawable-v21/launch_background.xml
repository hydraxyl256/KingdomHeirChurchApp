<?xml version="1.0" encoding="utf-8"?>
<!-- Native Android splash (API 21+) shown while Flutter engine initialises.
     Background matches the Flutter SplashScreen so there is no visible flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark navy background — same as AppColors.navy (#0F172A) -->
    <item android:drawable="@color/splashBackground" />
    <!-- Centered circular app icon (120dp × 120dp) -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_splash_logo" />
    </item>
</layer-list>
